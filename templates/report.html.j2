<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Barrierefreiheits-Report – {{ scan.name }}</title>
    <style>
        /* Grundlayout */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: #1a1a1a;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background: #fff;
        }

        /* Header */
        .header {
            background: #003366;
            color: white;
            padding: 30px 40px;
            border-radius: 8px;
            margin-bottom: 30px;
        }
        .header h1 { font-size: 1.8em; margin-bottom: 5px; }
        .header .subtitle { opacity: 0.9; font-size: 1.1em; }
        .header .meta { opacity: 0.7; font-size: 0.9em; margin-top: 15px; }

        /* Ampel-Bewertung */
        .ampel {
            display: inline-block;
            padding: 12px 24px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1.2em;
            margin: 20px 0;
        }
        .ampel.konform { background: #d4edda; color: #155724; }
        .ampel.teilweise { background: #fff3cd; color: #856404; }
        .ampel.nicht-konform { background: #f8d7da; color: #721c24; }

        /* Score-Kreis */
        .score-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8em;
            font-weight: bold;
            color: white;
            float: right;
        }
        .score-circle.green { background: #28a745; }
        .score-circle.yellow { background: #ffc107; color: #333; }
        .score-circle.red { background: #dc3545; }

        /* Zusammenfassung */
        .summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        .summary-card {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 6px;
            text-align: center;
            border-left: 4px solid #003366;
        }
        .summary-card .number { font-size: 2em; font-weight: bold; color: #003366; }
        .summary-card .label { color: #666; font-size: 0.9em; }
        .summary-card.hoch { border-left-color: #dc3545; }
        .summary-card.hoch .number { color: #dc3545; }
        .summary-card.mittel { border-left-color: #ffc107; }
        .summary-card.mittel .number { color: #856404; }
        .summary-card.niedrig { border-left-color: #17a2b8; }
        .summary-card.niedrig .number { color: #17a2b8; }

        /* Tabellen */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            font-size: 0.95em;
        }
        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #dee2e6;
        }
        th {
            background: #003366;
            color: white;
            font-weight: 600;
        }
        tr:hover { background: #f8f9fa; }

        /* Schweregrad-Badges */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 0.85em;
            font-weight: 600;
        }
        .badge.hoch { background: #f8d7da; color: #721c24; }
        .badge.mittel { background: #fff3cd; color: #856404; }
        .badge.niedrig { background: #d1ecf1; color: #0c5460; }
        .badge.A { background: #e2e3e5; color: #383d41; }
        .badge.AA { background: #d4edda; color: #155724; }

        /* Code-Blöcke */
        code {
            background: #f4f4f4;
            padding: 2px 6px;
            border-radius: 3px;
            font-family: "Consolas", "Monaco", monospace;
            font-size: 0.9em;
        }
        pre {
            background: #2d2d2d;
            color: #f8f8f2;
            padding: 15px;
            border-radius: 6px;
            overflow-x: auto;
            margin: 10px 0;
        }
        pre code { background: none; color: inherit; padding: 0; }

        /* KI-Vorschläge */
        .ai-suggestion {
            background: #e8f5e9;
            border-left: 4px solid #4caf50;
            padding: 15px;
            margin: 10px 0;
            border-radius: 0 6px 6px 0;
        }
        .ai-suggestion .ai-label {
            font-weight: bold;
            color: #2e7d32;
            margin-bottom: 5px;
        }
        .ai-suggestion .confidence {
            font-size: 0.85em;
            color: #666;
        }

        /* Abschnitte */
        .section {
            margin: 40px 0;
            padding-top: 20px;
        }
        .section h2 {
            color: #003366;
            border-bottom: 2px solid #003366;
            padding-bottom: 8px;
            margin-bottom: 20px;
        }
        .section h3 {
            color: #333;
            margin: 20px 0 10px;
        }

        /* Warnhinweis */
        .disclaimer {
            background: #fff3cd;
            border: 1px solid #ffc107;
            padding: 15px 20px;
            border-radius: 6px;
            margin: 20px 0;
            font-size: 0.9em;
        }

        /* Footer */
        .footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #dee2e6;
            text-align: center;
            color: #666;
            font-size: 0.85em;
        }

        /* Druck-Optimierung */
        @media print {
            body { padding: 0; max-width: 100%; }
            .header { border-radius: 0; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .ampel, .score-circle, .badge, th { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .section { page-break-inside: avoid; }
            table { page-break-inside: auto; }
            tr { page-break-inside: avoid; }
            pre { white-space: pre-wrap; word-wrap: break-word; }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="header" role="banner">
        <h1>🏛️ Barrierefreiheits-Report</h1>
        <div class="subtitle">{{ scan.name }}</div>
        <div class="meta">
            URL: {{ scan.url }} | Prüfer: {{ scan.pruefer or '–' }} |
            Datum: {{ generated_at }} | Version: {{ version }}
        </div>
    </div>

    <!-- Warnhinweis -->
    <div class="disclaimer" role="alert">
        <strong>⚠️ Hinweis:</strong> Dieser Report wurde mit automatisierten Werkzeugen und KI erstellt.
        Er ersetzt keine manuelle Prüfung durch zertifizierte Auditoren. KI-generierte Vorschläge
        können ungenau sein und sollten immer manuell überprüft werden.
    </div>

    <!-- Bewertung -->
    <div class="section">
        <h2>Gesamtbewertung</h2>

        {% set ampel_class = 'konform' if score >= 90 else ('teilweise' if score >= 60 else 'nicht-konform') %}
        {% set circle_class = 'green' if score >= 90 else ('yellow' if score >= 60 else 'red') %}

        <div class="score-circle {{ circle_class }}">{{ score }}%</div>
        <div class="ampel {{ ampel_class }}">{{ label }}</div>

        <div class="summary">
            <div class="summary-card">
                <div class="number">{{ pages|length }}</div>
                <div class="label">Seiten geprüft</div>
            </div>
            <div class="summary-card">
                <div class="number">{{ violations_data|length }}</div>
                <div class="label">Verstöße gesamt</div>
            </div>
            <div class="summary-card hoch">
                <div class="number">{{ hoch|length }}</div>
                <div class="label">🔴 Hoch</div>
            </div>
            <div class="summary-card mittel">
                <div class="number">{{ mittel|length }}</div>
                <div class="label">🟡 Mittel</div>
            </div>
            <div class="summary-card niedrig">
                <div class="number">{{ niedrig|length }}</div>
                <div class="label">🔵 Niedrig</div>
            </div>
        </div>
    </div>

    <!-- Verstöße nach Kriterium -->
    <div class="section">
        <h2>Verstöße nach WCAG-Kriterium</h2>
        <table>
            <thead>
                <tr>
                    <th>Kriterium</th>
                    <th>Name</th>
                    <th>Level</th>
                    <th>Anzahl</th>
                </tr>
            </thead>
            <tbody>
                {% for crit, data in violations_per_criterion.items() %}
                <tr>
                    <td><strong>{{ crit }}</strong></td>
                    <td>{{ data.name }}</td>
                    <td><span class="badge {{ data.level }}">{{ data.level }}</span></td>
                    <td>{{ data.count }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Detailansicht pro Seite -->
    <div class="section">
        <h2>Verstöße im Detail</h2>

        {% for page_url, violations in violations_per_page.items() %}
        <h3>📄 {{ page_url }}</h3>
        <table>
            <thead>
                <tr>
                    <th>Kriterium</th>
                    <th>Beschreibung</th>
                    <th>Schweregrad</th>
                    <th>Element</th>
                </tr>
            </thead>
            <tbody>
                {% for v in violations %}
                <tr>
                    <td><strong>{{ v.violation.criterion }}</strong></td>
                    <td>{{ v.violation.description }}</td>
                    <td><span class="badge {{ v.violation.severity }}">{{ v.violation.severity }}</span></td>
                    <td><code>{{ v.violation.element[:80] }}</code></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- KI-Vorschläge -->
        {% for v in violations %}
            {% if v.suggestions %}
                {% for s in v.suggestions %}
                <div class="ai-suggestion">
                    <div class="ai-label">💡 KI-Korrekturvorschlag für {{ v.violation.criterion }}</div>
                    <p>{{ s.suggestion_text }}</p>
                    {% if s.fix_code %}
                        <p><strong>Korrigierter Code:</strong></p>
                        <pre><code>{{ s.fix_code }}</code></pre>
                    {% endif %}
                    <div class="confidence">Konfidenz: {{ (s.confidence * 100)|round(0) }}%</div>
                </div>
                {% endfor %}
            {% endif %}
        {% endfor %}

        {% endfor %}
    </div>

    <!-- Geprüfte Seiten -->
    <div class="section">
        <h2>Geprüfte Seiten</h2>
        <table>
            <thead>
                <tr>
                    <th>URL</th>
                    <th>Titel</th>
                    <th>Status</th>
                    <th>Verstöße</th>
                </tr>
            </thead>
            <tbody>
                {% for page in pages %}
                <tr>
                    <td><a href="{{ page.url }}">{{ page.url[:80] }}</a></td>
                    <td>{{ page.title[:60] }}</td>
                    <td>{{ page.status_code }}</td>
                    <td>{{ violations_per_page.get(page.url, [])|length }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Footer -->
    <div class="footer" role="contentinfo">
        <p>Erstellt mit KI-Barrierefreiheits-Prüfer v{{ version }} | {{ generated_at }}</p>
        <p>Dieser Report ersetzt keine zertifizierte Barrierefreiheitsprüfung.</p>
    </div>

</body>
</html>
