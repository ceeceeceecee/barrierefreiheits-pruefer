# KI-Barrierefreiheits-Prüfer – Umgebungsvariablen

# Datenbank
DB_PATH=./data/barrierefreiheit.db

# Report-Verzeichnis
REPORT_DIR=./reports

# KI-Provider: ollama oder claude
AI_PROVIDER=ollama

# Ollama Einstellungen (lokal, DSGVO-konform)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Claude API (optional – externe API, DSGVO-Prüfung empfohlen)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
